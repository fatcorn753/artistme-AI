{
  "manifest_version": 3,
  "name": "Regex Tester",
  "version": "1.0.0",
  "description": "正規表現をリアルタイムでテスト。マッチ箇所のハイライト、グループ表示、よく使うパターン集付き。",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
