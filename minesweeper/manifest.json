{
  "manifest_version": 3,
  "name": "Minesweeper",
  "version": "1.0.0",
  "description": "クラシックなマインスイーパー。初級/中級/上級の3難易度、右クリックで旗を立て、タイム計測付き。",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
