{
  "manifest_version": 3,
  "name": "Focus Mode — Site Blocker",
  "version": "1.0.0",
  "description": "集中モード中に気が散るサイトをブロック。タイマー付きで指定時間集中できます。",
  "permissions": ["storage", "alarms", "declarativeNetRequest", "declarativeNetRequestFeedback"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "declarative_net_request": {
    "rule_resources": [{
      "id": "block_rules",
      "enabled": false,
      "path": "rules.json"
    }]
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
