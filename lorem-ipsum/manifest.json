{
  "manifest_version": 3,
  "name": "Lorem Ipsum Generator",
  "version": "1.0.0",
  "description": "Lorem Ipsum・日本語ダミーテキスト・HTMLタグ付きテキストを即生成。段落数・語数・文字数を指定可能。",
  "permissions": ["storage", "clipboardWrite"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
