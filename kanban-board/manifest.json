{
  "manifest_version": 3,
  "name": "Kanban Board",
  "version": "1.0.0",
  "description": "シンプルなカンバンボード。ToDo・進行中・完了の3列でタスクをドラッグ&ドロップ管理。複数ボード対応。",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
