{
  "manifest_version": 3,
  "name": "Flashcard Web",
  "version": "1.0.0",
  "description": "視覚的なフラッシュカード学習。3Dカードフリップアニメーション、SM-2間隔反復、カテゴリ管理、進捗グラフ。",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
