{
  "manifest_version": 3,
  "name": "Meeting Notes",
  "version": "1.0.0",
  "description": "会議メモを素早く記録。アジェンダ・決定事項・アクションアイテム・タイマー付き。Markdown対応でエクスポート可能。",
  "permissions": ["storage", "alarms", "notifications"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": { "service_worker": "background.js" },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
