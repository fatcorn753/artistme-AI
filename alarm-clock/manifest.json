{
  "manifest_version": 3,
  "name": "Alarm Clock",
  "version": "1.0.0",
  "description": "多機能アラーム時計。複数アラーム・スヌーズ・繰り返し設定・カウントダウンタイマー・アナログ時計表示。",
  "permissions": ["storage", "alarms", "notifications"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": { "service_worker": "background.js" },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
