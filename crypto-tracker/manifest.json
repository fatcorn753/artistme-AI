{
  "manifest_version": 3,
  "name": "Crypto Price Tracker",
  "version": "1.0.0",
  "description": "仮想通貨のリアルタイム価格追跡・ポートフォリオ管理。CoinGecko API使用、価格アラート、24h変動率、チャート付き。",
  "permissions": ["storage", "alarms", "notifications"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": { "service_worker": "background.js" },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
