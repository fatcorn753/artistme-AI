{
  "manifest_version": 3,
  "name": "Clipboard History",
  "version": "1.0.0",
  "description": "コピーした内容を自動保存。最大50件の履歴から検索・再コピーできるクリップボード管理ツール。",
  "permissions": ["storage", "clipboardRead", "clipboardWrite", "activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
