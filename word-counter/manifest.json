{
  "manifest_version": 3,
  "name": "Word Counter",
  "version": "1.0.0",
  "description": "テキストの文字数・語数・行数・文数・読了時間をリアルタイムで計測。よく使う文字数制限のチェックも可能。",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
