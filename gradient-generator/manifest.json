{
  "manifest_version": 3,
  "name": "Gradient Generator",
  "version": "1.0.0",
  "description": "美しいCSSグラデーションをビジュアルに作成。角度・色・位置を自由に設定してCSS/Tailwindコードを即コピー。",
  "permissions": ["storage", "clipboardWrite"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
