{
  "manifest_version": 3,
  "name": "Markdown Slides",
  "version": "1.0.0",
  "description": "Markdownからプレゼンスライドを生成。--- で区切ってスライド作成、テーマ選択、フルスクリーン表示対応。",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
