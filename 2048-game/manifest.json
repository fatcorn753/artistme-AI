{
  "manifest_version": 3,
  "name": "2048",
  "version": "1.0.0",
  "description": "2048パズルゲーム。スワイプ・キーボード操作、スコア記録、アニメーション、最高スコア永続化。",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
