{
  "manifest_version": 3,
  "name": "Study Timer",
  "version": "1.0.0",
  "description": "科目別学習タイマー。ポモドーロ・自由タイマー・目標時間設定・週次グラフ・連続学習記録。勉強の習慣化をサポート。",
  "permissions": ["storage", "alarms", "notifications"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": { "service_worker": "background.js" },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
