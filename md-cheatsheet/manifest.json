{
  "manifest_version": 3,
  "name": "Markdown Cheatsheet",
  "version": "1.0.0",
  "description": "Markdownの構文チートシート。クリックでコピー、ライブプレビュー、GitHub/CommonMark両対応、検索機能付き。",
  "permissions": ["storage", "clipboardWrite"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
