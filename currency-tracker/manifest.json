{
  "manifest_version": 3,
  "name": "Currency Rate Tracker",
  "version": "1.0.0",
  "description": "為替レートの日次追跡・履歴グラフ・変動アラート。Frankfurter APIで30日分のレート変動を可視化。",
  "permissions": ["storage", "alarms", "notifications"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": { "service_worker": "background.js" },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
