{
  "manifest_version": 3,
  "name": "Breakout",
  "version": "1.0.0",
  "description": "ブロック崩しゲーム。パワーアップ・ボールスピードアップ・マルチボール・レベル制・ハイスコア記録。",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
