{
  "manifest_version": 3,
  "name": "GitHub Profile Viewer",
  "version": "1.0.0",
  "description": "GitHubユーザーのプロフィール・リポジトリ・コントリビューション・言語統計を即表示。Star/Fork/Issue数付き。",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
