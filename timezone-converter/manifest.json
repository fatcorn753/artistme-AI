{
  "manifest_version": 3,
  "name": "Time Zone Converter",
  "version": "1.0.0",
  "description": "世界の時刻をリアルタイム変換。会議時間調整、複数都市の時刻比較、サマータイム自動対応。",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
