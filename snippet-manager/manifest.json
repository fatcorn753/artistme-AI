{
  "manifest_version": 3,
  "name": "Code Snippet Manager",
  "version": "1.0.0",
  "description": "コードスニペットを保存・管理。タグ検索、シンタックスハイライト、ワンクリックコピー対応。",
  "permissions": ["storage", "clipboardWrite"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
